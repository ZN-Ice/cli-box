{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "System Test Sandbox",
  "version": "0.1.0",
  "identifier": "com.system-test-sandbox.app",
  "build": {
    "frontendDist": "../sandbox-web/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd ../sandbox-web && pnpm dev",
    "beforeBuildCommand": "cd ../sandbox-web && pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "sandbox",
        "title": "System Test Sandbox",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
